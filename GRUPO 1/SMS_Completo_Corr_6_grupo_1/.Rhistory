# Exemplo de dataset
set.seed(123)
dados <- data.frame(
x1 = rnorm(1000),
x2 = rnorm(1000),
classe = c(rep("A", 800), rep("B", 200))  # Exemplo de desbalanceamento (80% - 20%)
)
# Separando X e y
X <- dados[, c("x1", "x2")]
y <- dados$classe
# Downsample
library(caret)
dados_down <- downSample(x = X, y = y)
head(dados_down)
table(dados_down$Class)  # Verificar equilíbrio
# Preparando o dataset: última coluna deve ser a classe
dados_smote <- dados
dados_smote$classe <- as.factor(dados_smote$classe)
# Aplicando SMOTE
set.seed(123)
dados_smote_bal <- SMOTE(classe ~ ., data = dados_smote,
perc.over = 200,  # quantos % a mais de instâncias minoritárias
perc.under = 200) # quantos % reduzir da classe majoritária
