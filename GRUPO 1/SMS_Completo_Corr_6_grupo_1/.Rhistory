pred_class <- factor(data$pred, levels = lev)
# Calcular as métricas Precision, Recall e F1
precision <- posPredValue(pred_class, data$obs, positive = lev[1])
recall <- sensitivity(pred_class, data$obs, positive = lev[1])
f1 <- (2 * precision * recall) / (precision + recall)
out <- c(Precision = precision, Recall = recall, F1 = f1)
return(out)
}
# Função para calcular todas as métricas
calculate_metrics <- function(model, X, y, control) {
set.seed(42)  # Definir semente dentro da função também, para garantir consistência
model_fit <- train(X, y, method = model, trControl = control, summaryFunction = customSummary)
return(model_fit)
}
