# Definir a semente aleatória para reprodutibilidade
set.seed(42)
# Criar um conjunto de dados artificial extremamente desbalanceado
n <- 1000
X1 <- rnorm(n)
X2 <- rnorm(n)
# Criando uma classe extremamente desbalanceada (99% classe majoritária)
y <- ifelse(runif(n) < 0.99, "major_class", "minor_class")
data <- data.frame(X1 = X1, X2 = X2, y = as.factor(y))
# Separar os dados e as classes
