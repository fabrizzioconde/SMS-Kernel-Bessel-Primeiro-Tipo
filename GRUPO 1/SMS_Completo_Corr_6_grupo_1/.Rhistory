# Definir função de avaliação que inclui Acurácia, Precision, Recall, F1 Score e Log Loss
customSummary <- function(data, lev = NULL, model = NULL) {
# Obter predições binárias
pred_class <- factor(data$pred, levels = lev)
# Calcular as métricas Precision, Recall e F1
precision <- posPredValue(pred_class, data$obs, positive = lev[1])
recall <- sensitivity(pred_class, data$obs, positive = lev[1])
f1 <- (2 * precision * recall) / (precision + recall)
# Calcular Acurácia
accuracy <- sum(pred_class == data$obs) / length(data$obs)
# Calcular Log Loss (usando as probabilidades preditas)
log_loss <- mnLogLoss(data = data, lev = lev)
# Calcular F1 Score para cada classe
f1_major_class <- F1_Score(pred_class, data$obs, positive = "major_class")
f1_minor_class <- F1_Score(pred_class, data$obs, positive = "minor_class")
# Calcular o suporte (frequência) de cada classe
support_major_class <- sum(data$obs == "major_class")
support_minor_class <- sum(data$obs == "minor_class")
total_samples <- length(data$obs)
# Calcular F1 Score ponderado
f1_weighted <- (support_major_class * f1_major_class + support_minor_class * f1_minor_class) / total_samples
out <- c(Accuracy = accuracy, Precision = precision, Recall = recall, F1 = f1, LogLoss = log_loss, F1_weighted = f1_weighted)
return(out)
}
# Função para calcular todas as métricas
calculate_metrics <- function(model, X, y, control) {
set.seed(42)  # Definir semente dentro da função também, para garantir consistência
model_fit <- train(X, y, method = model, trControl = control, summaryFunction = customSummary)
return(model_fit)
}
# Controle para validação cruzada sem estratificação
control_non_stratified <- trainControl(method = "cv",
number = 10,
summaryFunction = customSummary,
classProbs = TRUE)
# Controle para validação cruzada com estratificação
control_stratified <- trainControl(method = "cv",
number = 10,
summaryFunction = customSummary,
savePredictions = "final",
classProbs = TRUE)
# Modelos a serem avaliados
models <- list("Random Forest" = "rf", "SVM Radial" = "svmRadial")
# Calcular as métricas para Random Forest e SVM Radial sem estratificação
model_rf_non_stratified <- calculate_metrics(models[["Random Forest"]], X, y, control_non_stratified)
model_svm_non_stratified <- calculate_metrics(models[["SVM Radial"]], X, y, control_non_stratified)
# Calcular as métricas para Random Forest e SVM Radial com estratificação
model_rf_stratified <- calculate_metrics(models[["Random Forest"]], X, y, control_stratified)
model_svm_stratified <- calculate_metrics(models[["SVM Radial"]], X, y, control_stratified)
# Exibir os resultados
