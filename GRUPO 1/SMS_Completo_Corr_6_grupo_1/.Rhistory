# Instale o pacote PRROC caso ainda não tenha instalado
if (!requireNamespace("PRROC", quietly = TRUE)) {
install.packages("PRROC")
}
# Carregar o pacote
library(PRROC)
# Simular dados de exemplo
# Scores de probabilidade previstos pelo modelo
predicted_scores <- c(0.9, 0.8, 0.4, 0.7, 0.2, 0.1, 0.95, 0.5, 0.6, 0.3)
# Rótulos verdadeiros (1 = positivo, 0 = negativo)
true_labels <- c(1, 1, 0, 1, 0, 0, 1, 0, 1, 0)
# Criar um objeto PRROC com os scores previstos e os rótulos verdadeiros
pr <- pr.curve(scores.class0 = predicted_scores, weights.class0 = true_labels, curve = TRUE)
# Imprimir a área sob a curva Precision-Recall (AUC-PR)
cat("AUC-PR:", pr$auc.integral, "\n")
# Plotar a curva Precision-Recall
plot(pr, main = "Precision-Recall Curve", col = "blue", lwd = 2)
