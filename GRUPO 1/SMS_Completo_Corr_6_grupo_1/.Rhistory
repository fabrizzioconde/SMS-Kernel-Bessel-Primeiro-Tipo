# Pacote
library(scrime)
# Parâmetros
n.obs   <- 1000  # Nº de indivíduos
n.snp   <- 100     # Nº total de SNPs
beta0   <- 0     # Intercepto
betaVec <- c(2, 1.3, 0.9, 2, 3)  # Efeitos
list.ia<-list(1, 3, 2, c(-1,3),c(1,2,3))  #Contrução das iterações entre os 5 marcadores causais
list.snp<-list(1, 2, 3, c(4,5),c(6,7,8))  #Indica quais são os marcadores causais
# Frequência alélica mínima e máxima
mafVec <- c(0.1, 0.4)
# Gerando a simulação
#set.seed(123)
sim <- simulateSNPglm(
n.obs   = n.obs,
n.snp   = n.snp,
list.snp= list.snp,
list.ia = list.ia,
beta0   = beta0,
beta    = betaVec,
maf     = mafVec,
err.fun = runif,  # ruído ~ distribuição uniforme
rand    = 123
)
# "sim$x" contém os genótipos (SNP1..SNP8)
# "sim$y" contém o valor linear + ruído (logístico) => Precisamos converter para probabilidade.
linpred <- sim$y
prob    <- plogis(linpred)
# Definimos Y=1 se prob > 0.7
Y <- as.numeric(prob > 0.7)
# Criando data.frame final
dados <- data.frame(sim$x, prob=prob, fenotipo=Y)
head(dados)
table(dados$fenotipo)
